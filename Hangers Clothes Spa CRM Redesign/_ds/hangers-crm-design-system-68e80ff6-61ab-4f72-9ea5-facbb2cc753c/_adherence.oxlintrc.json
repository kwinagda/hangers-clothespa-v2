{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/general/Badge/**",
              "components/general/Button/**",
              "components/general/EmptyState/**",
              "components/general/ErrorState/**",
              "components/general/InlineLoader/**",
              "components/general/PageHeader/**",
              "components/general/PaginationControls/**",
              "components/general/SkeletonCard/**",
              "components/general/SkeletonLine/**",
              "components/general/StatCard/**",
              "components/general/TableLoader/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|Space Grotesk|Space Mono))/i]",
        "message": "Font not provided by the design system. Available: Inter, Space Grotesk, Space Mono."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "Badge": {
        "replaces": []
      },
      "Button": {
        "replaces": []
      },
      "EmptyState": {
        "replaces": []
      },
      "ErrorState": {
        "replaces": []
      },
      "InlineLoader": {
        "replaces": []
      },
      "PageHeader": {
        "replaces": []
      },
      "PaginationControls": {
        "replaces": []
      },
      "SkeletonCard": {
        "replaces": []
      },
      "SkeletonLine": {
        "replaces": []
      },
      "StatCard": {
        "replaces": []
      },
      "TableLoader": {
        "replaces": []
      }
    },
    "tokens": [
      "--crm-ease",
      "--crm-font-display",
      "--crm-font-mono",
      "--crm-font-ui",
      "--crm-shadow-float",
      "--crm-shadow-soft",
      "--tw-backdrop-blur",
