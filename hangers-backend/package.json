{
  "name": "hangers-backend",
  "version": "1.0.0",
  "description": "Hangers Clothes Spa - Backend API",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "node --test tests/*.test.js",
    "type:check": "tsc --noEmit",
    "postinstall": "npx prisma generate",
    "fabklean:payments": "node scripts/import-fabklean-payments.mjs",
    "start:prod": "npx prisma migrate deploy && node src/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.79.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "expo-server-sdk": "^3.7.0",
    "express": "^4.22.1",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "puppeteer": "^24.39.1",
    "razorpay": "^2.9.6",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.3",
    "prisma": "^5.10.0",
    "typescript": "^5.9.3"
  }
}
