# ─────────────────────────────────────────────────────────────
# HANGERS CLOTHES SPA — BACKEND ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your real values
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database (PostgreSQL) ─────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/hangers_db"

# ── JWT Secrets ───────────────────────────────────────────────
# Use a long random string — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="REPLACE_WITH_LONG_RANDOM_STRING_MIN_64_CHARS"
JWT_CUSTOMER_EXPIRES_IN="30d"
JWT_STAFF_EXPIRES_IN="12h"

# ── MSG91 (OTP / SMS) ─────────────────────────────────────────
# Get from: msg91.com → API → Credentials
MSG91_AUTH_KEY="YOUR_MSG91_AUTH_KEY"
MSG91_TEMPLATE_ID="YOUR_OTP_TEMPLATE_ID"
MSG91_SENDER_ID="HNGRS"

# ── Razorpay ──────────────────────────────────────────────────
# Test keys for now — swap with live keys before launch
RAZORPAY_KEY_ID="rzp_test_XXXXXXXXXXXXXXXXXX"
RAZORPAY_KEY_SECRET="XXXXXXXXXXXXXXXXXXXXXXXX"

# ── Shop Info ─────────────────────────────────────────────────
SHOP_NAME="Hangers Clothes Spa"
SHOP_PHONE="+91 7977417014"
SHOP_TAGLINE="Care in Every Clean"

# ── Frontend URLs (for CORS) ──────────────────────────────────
CRM_URL="http://localhost:3000"
CUSTOMER_APP_URL="http://localhost:3001"
