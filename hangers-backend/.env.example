PORT=5001
NODE_ENV=development
BUSINESS_TIMEZONE=Asia/Kolkata
BUSINESS_UTC_OFFSET=+05:30
IRON_LOG_BACKDATE_DAYS=7

DATABASE_URL="postgresql://postgres:password@localhost:5432/hangers_db"

JWT_SECRET="replace_with_a_long_random_secret"
JWT_CUSTOMER_EXPIRES_IN=30d
JWT_STAFF_EXPIRES_IN=12h

CRM_URL=http://localhost:5002
CUSTOMER_APP_URL=http://localhost:8081
STAFF_APP_URL=http://localhost:8082
# Production must use HTTPS origins only, comma-separated.
# Example: ALLOWED_ORIGINS=https://crm.example.com,https://app.example.com
ALLOWED_ORIGINS=

# Required in production for notification/PDF workers.
REDIS_URL=

DEV_MODE=true
WA_DELIVERY_OTP_DEV=true

MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=HNGRS

META_WA_PHONE_NUMBER_ID=
META_WA_ACCESS_TOKEN=
META_WA_OTP_TEMPLATE=hangers_otp

WHATOMATE_TEMPLATE_URL=https://whatomate-production-949e.up.railway.app/api/messages/template
WHATOMATE_API_KEY=
WHATOMATE_ACCOUNT_NAME=Hangers
WHATOMATE_SEND_IN_DEV=false

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
