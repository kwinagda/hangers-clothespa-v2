generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id                  String               @id @default(uuid())
  phone               String               @unique
  name                String?
  sessionVersion      Int                  @default(0)
  ironRateOverride    Decimal?             @db.Decimal(18, 2)
  preferredLanguage   String               @default("ENGLISH")
  ironSubStatus       String?
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  notifPush           Boolean              @default(true)
  notifWhatsApp       Boolean              @default(true)
  pushToken           String?
  dob                 DateTime?
  ordersDue           Decimal              @default(0) @db.Decimal(18, 2)
  referralCode        String?              @unique
  referredById        String?
  walletBalance       Decimal              @default(0) @db.Decimal(18, 2)
  loyaltyPoints       Int                  @default(0)
  notes               String?
  tag                 String?              @default("REGULAR")
  mapLocation         String?
  orders              Order[]
  addresses           Address[]
  sessions            CustomerSession[]
  referrer            Customer?            @relation("ReferredBy", fields: [referredById], references: [id])
  referred            Customer[]           @relation("ReferredBy")
  loyaltyTransactions LoyaltyTransaction[]
  otps                OtpVerification[]
  recurringPickups    RecurringPickup[]
  referralReceived    Referral?            @relation("ReferralReceived")
  referralsMade       Referral[]           @relation("ReferralsMade")
  walletTxns          WalletTransaction[]
  ironSubscription    IronSubscription?
  ironLogs            IronLog[]
  ironBills           IronBill[]
  invoices            Invoice[]
  payments            Payment[]
  creditNotes         CreditNote[]
  receipts            Receipt[]
  returnCases         ReturnCase[]

  @@map("customers")
}

model Address {
  id           String   @id @default(uuid())
  customerId   String
  label        String   @default("Home")
  addressLine1 String
  addressLine2 String?
  landmark     String?
  city         String
  pincode      String
  latitude     Float?
  longitude    Float?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

model Staff {
  id                           String                  @id @default(uuid())
  name                         String
  phone                        String                  @unique
  email                        String?                 @unique
  passwordHash                 String
  sessionVersion               Int                     @default(0)
  mustChangePassword           Boolean                 @default(false)
  role                         StaffRole
  isActive                     Boolean                 @default(true)
  pin                          String?
  createdBy                    String?
  lastLoginAt                  DateTime?
  createdAt                    DateTime                @default(now())
  updatedAt                    DateTime                @updatedAt
  orders                       Order[]
  stageChanges                 OrderStage[]
  paymentsCollected            Payment[]
  discountApprovals            Order[]                 @relation("OrderDiscountApprovedBy")
  writeOffApprovals            Order[]                 @relation("OrderWriteOffApprovedBy")
  priceOverrides               OrderItem[]             @relation("OrderItemPriceOverriddenBy")
  financialAdjustmentsCreated  FinancialAdjustment[]   @relation("FinancialAdjustmentCreatedBy")
  financialAdjustmentsApproved FinancialAdjustment[]   @relation("FinancialAdjustmentApprovedBy")
  walletTransactionsCreated    WalletTransaction[]     @relation("WalletTransactionCreatedBy")
  walletTransactionsApproved   WalletTransaction[]     @relation("WalletTransactionApprovedBy")
  cashEntries                  CashBook[]
  expensesCreated              Expense[]               @relation("ExpenseCreatedBy")
  expensesApproved             Expense[]               @relation("ExpenseApprovedBy")
  expensesVoided               Expense[]               @relation("ExpenseVoidedBy")
  invoicesCreated              Invoice[]               @relation("InvoiceCreatedBy")
  invoicesPosted               Invoice[]               @relation("InvoicePostedBy")
  invoiceRevisions             InvoiceRevision[]       @relation("InvoiceRevisionCreatedBy")
  creditNotesCreated           CreditNote[]            @relation("CreditNoteCreatedBy")
  creditNotesApproved          CreditNote[]            @relation("CreditNoteApprovedBy")
  receiptsIssued               Receipt[]               @relation("ReceiptIssuedBy")
  returnCasesCreated           ReturnCase[]            @relation("ReturnCaseCreatedBy")
  returnCasesResolved          ReturnCase[]            @relation("ReturnCaseResolvedBy")
  challanReceipts              ChallanReceipt[]
  plantIssuesReported          PlantQualityIssue[]     @relation("PlantIssueReportedBy")
  plantIssuesResolved          PlantQualityIssue[]     @relation("PlantIssueResolvedBy")
  vendorBillsApproved          VendorBill[]            @relation("VendorBillApprovedBy")
  vendorPaymentsRecorded       VendorPayment[]         @relation("VendorPaymentRecordedBy")
  deliveryAssignments          DeliveryAssignment[]    @relation("DeliveryAssignee")
  deliveryAssignmentsCreated   DeliveryAssignment[]    @relation("DeliveryAssignedBy")
  deliveryAttempts             DeliveryAttempt[]       @relation("DeliveryAttemptedBy")
  attendance                   Attendance[]
  permissions                  StaffPermission[]
  serviceAllowances            StaffServiceAllowance[]
  sessions                     StaffSession[]
  ironSubscriptionsConfirmed   IronSubscription[]      @relation("IronSubscriptionConfirmedBy")
  ironLogsEntered              IronLog[]               @relation("IronLogEnteredBy")
  ironLogsVoided               IronLog[]               @relation("IronLogVoidedBy")

  @@map("staff")
}

model StaffPermission {
  id         String  @id @default(uuid())
  staffId    String
  permission String
  granted    Boolean @default(true)
  staff      Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, permission])
  @@map("staff_permissions")
}

model CustomerSession {
  id         String   @id @default(uuid())
  customerId String
  token      String   @unique
  deviceInfo String?
  ipAddress  String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_sessions")
}

model StaffSession {
  id         String   @id @default(uuid())
  staffId    String
  token      String?  @unique
  tokenHash  String?  @unique
  sessionId  String?  @unique
  deviceInfo String?
  ipAddress  String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  staff      Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@map("staff_sessions")
}

model OtpVerification {
  id          String     @id @default(uuid())
  phone       String
  otp         String
  purpose     OtpPurpose @default(LOGIN)
  attempts    Int        @default(0)
  maxAttempts Int        @default(3)
  isUsed      Boolean    @default(false)
  expiresAt   DateTime
  createdAt   DateTime   @default(now())
  customerId  String?
  customer    Customer?  @relation(fields: [customerId], references: [id])

  @@map("otp_verifications")
}

model ActivityLog {
  id          String   @id @default(uuid())
  actorType   String
  actorId     String?
  actorName   String?
  action      String
  resource    String?
  resourceId  String?
  description String
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([actorId])
  @@index([resourceId])
  @@index([action])
  @@index([createdAt])
  @@map("activity_logs")
}

model AuditLog {
  id          String           @id @default(uuid())
  actorType   String
  actorId     String?
  actorName   String?
  action      String
  status      AuditEventStatus @default(SUCCESS)
  resource    String?
  resourceId  String?
  description String
  metadata    Json?
  route       String?
  method      String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime         @default(now())

  @@index([actorId])
  @@index([action])
  @@index([status])
  @@index([createdAt])
  @@map("audit_logs")
}

model AuthThrottle {
  id           String    @id @default(uuid())
  scope        String
  scopeKey     String
  failureCount Int       @default(0)
  blockedUntil DateTime?
  lastFailedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([scope, scopeKey])
  @@index([blockedUntil])
  @@index([scope, blockedUntil])
  @@map("auth_throttles")
}

model PermissionCatalog {
  id           String                @id @default(uuid())
  code         String                @unique
  category     String?
  description  String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  roleBindings StaffRolePermission[]

  @@index([category])
  @@map("permission_catalog")
}

model StaffRolePermission {
  id             String            @id @default(uuid())
  role           StaffRole
  permissionCode String
  createdAt      DateTime          @default(now())
  permission     PermissionCatalog @relation(fields: [permissionCode], references: [code], onDelete: Cascade)

  @@unique([role, permissionCode])
  @@index([permissionCode])
  @@map("staff_role_permissions")
}

model StaffServiceAllowance {
  id          String   @id @default(uuid())
  staffId     String
  serviceCode String
  allowed     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  staff       Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, serviceCode])
  @@index([serviceCode])
  @@map("staff_service_allowances")
}

model AuthChallenge {
  id            String               @id @default(uuid())
  subjectType   String
  subjectKey    String
  purpose       AuthChallengePurpose
  status        AuthChallengeStatus  @default(PENDING)
  hashedCode    String
  attemptCount  Int                  @default(0)
  maxAttempts   Int                  @default(5)
  resendCount   Int                  @default(0)
  lastSentAt    DateTime             @default(now())
  cooldownUntil DateTime?
  expiresAt     DateTime
  consumedAt    DateTime?
  metadata      Json?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([subjectType, subjectKey, purpose])
  @@index([status, expiresAt])
  @@map("auth_challenges")
}

model PublicShareToken {
  id           String    @id @default(uuid())
  tokenHash    String    @unique
  resourceType String
  resourceId   String
  purpose      String
  expiresAt    DateTime
  revokedAt    DateTime?
  accessCount  Int       @default(0)
  lastAccessAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([resourceType, resourceId, purpose])
  @@index([expiresAt])
  @@map("public_share_tokens")
}

model Order {
  id                    String                @id @default(cuid())
  orderNumber           String                @unique
  customerId            String
  status                OrderStatus           @default(PENDING)
  documentType          String                @default("ORDER")
  source                String                @default("COUNTER")
  quotationStatus       String?
  validUntil            DateTime?
  convertedOrderId      String?
  subtotal              Decimal               @default(0) @db.Decimal(18, 2)
  discount              Decimal               @default(0) @db.Decimal(18, 2)
  discountReason        String?
  discountApprovedById  String?
  totalAmount           Decimal               @default(0) @db.Decimal(18, 2)
  paidAmount            Decimal               @default(0) @db.Decimal(18, 2)
  writeOffAmount        Decimal               @default(0) @db.Decimal(18, 2)
  writeOffReason        String?
  writeOffApprovedById  String?
  pickupDate            DateTime?
  deliveryDate          DateTime?
  deliveredAt           DateTime?
  notes                 String?
  assignedToId          String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  paymentStatus         String                @default("UNPAID")
  pickupAddress         String?
  pickupSlot            String?
  couponCode            String?
  couponDiscount        Decimal               @default(0) @db.Decimal(18, 2)
  loyaltyPointsRedeemed Int                   @default(0)
  loyaltyDiscount       Decimal               @default(0) @db.Decimal(18, 2)
  isReturn              Boolean               @default(false)
  originalOrderId       String?
  returnReason          String?
  upcharge              Decimal               @default(0) @db.Decimal(18, 2)
  pricingSnapshot       Json?
  version               Int                   @default(1)
  assignedTo            Staff?                @relation(fields: [assignedToId], references: [id])
  discountApprovedBy    Staff?                @relation("OrderDiscountApprovedBy", fields: [discountApprovedById], references: [id], onDelete: Restrict)
  writeOffApprovedBy    Staff?                @relation("OrderWriteOffApprovedBy", fields: [writeOffApprovedById], references: [id], onDelete: Restrict)
  customer              Customer              @relation(fields: [customerId], references: [id])
  items                 OrderItem[]
  stages                OrderStage[]
  payments              Payment[]
  paymentAllocations    PaymentAllocation[]
  challanOrders         ChallanOrder[]
  walletTxns            WalletTransaction[]
  financialAdjustments  FinancialAdjustment[]
  invoice               Invoice?
  creditNotes           CreditNote[]
  returnCasesAsOriginal ReturnCase[]          @relation("ReturnCaseOriginalOrder")
  returnCaseAsRework    ReturnCase?           @relation("ReturnCaseReworkOrder")
  plantQualityIssues    PlantQualityIssue[]
  deliveryAssignments   DeliveryAssignment[]
  deliveryAttempts      DeliveryAttempt[]

  @@index([customerId])
  @@index([status])
  @@index([documentType])
  @@index([quotationStatus])
  @@index([createdAt])
  @@index([assignedToId, status])
  @@index([status, pickupDate])
  @@index([customerId, status, createdAt])
}

model OrderItem {
  id                  String        @id @default(cuid())
  orderId             String
  serviceId           String?
  serviceName         String
  garmentType         String
  variant             String?
  quantity            Int           @default(1)
  baseUnitPrice       Decimal?      @db.Decimal(18, 2)
  unitPrice           Decimal       @db.Decimal(18, 2)
  lineDiscountType    String?
  lineDiscountValue   Decimal       @default(0) @db.Decimal(18, 4)
  lineDiscountAmount  Decimal       @default(0) @db.Decimal(18, 2)
  subtotal            Decimal       @db.Decimal(18, 2)
  catalogUnitPrice    Decimal?      @db.Decimal(18, 2)
  priceSource         String        @default("CATALOG")
  priceOverrideReason String?
  priceOverriddenById String?
  pricingSnapshot     Json?
  upcharges           String?
  notes               String?
  tagNumber           String?
  createdAt           DateTime      @default(now())
  order               Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  service             Service?      @relation(fields: [serviceId], references: [id])
  priceOverriddenBy   Staff?        @relation("OrderItemPriceOverriddenBy", fields: [priceOverriddenById], references: [id], onDelete: Restrict)
  challanItems        ChallanItem[]
  invoiceLines        InvoiceLine[]
  returnLines         ReturnLine[]
  garmentUnits        GarmentUnit[]

  @@index([orderId])
}

model DeliveryAssignment {
  id           String            @id @default(cuid())
  orderId      String
  kind         String            @default("DELIVERY")
  status       String            @default("ASSIGNED")
  assigneeId   String
  assignedById String
  scheduledAt  DateTime?
  acceptedAt   DateTime?
  completedAt  DateTime?
  cancelledAt  DateTime?
  cancelReason String?
  version      Int               @default(1)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  order        Order             @relation(fields: [orderId], references: [id], onDelete: Restrict)
  assignee     Staff             @relation("DeliveryAssignee", fields: [assigneeId], references: [id], onDelete: Restrict)
  assignedBy   Staff             @relation("DeliveryAssignedBy", fields: [assignedById], references: [id], onDelete: Restrict)
  attempts     DeliveryAttempt[]

  @@index([assigneeId, status, scheduledAt])
  @@index([orderId, kind, status])
  @@map("delivery_assignments")
}

model DeliveryAttempt {
  id                    String             @id @default(cuid())
  assignmentId          String
  orderId               String
  attemptedById         String
  outcome               String
  reasonCode            String?
  notes                 String?
  confirmationMethod    String?
  confirmationReference String?
  attemptedAt           DateTime           @default(now())
  assignment            DeliveryAssignment @relation(fields: [assignmentId], references: [id], onDelete: Restrict)
  order                 Order              @relation(fields: [orderId], references: [id], onDelete: Restrict)
  attemptedBy           Staff              @relation("DeliveryAttemptedBy", fields: [attemptedById], references: [id], onDelete: Restrict)

  @@index([orderId, attemptedAt])
  @@index([assignmentId, attemptedAt])
  @@map("delivery_attempts")
}

model OrderStage {
  id          String   @id @default(cuid())
  orderId     String
  stage       String
  eventType   String   @default("WORKFLOW_TRANSITION")
  fromStatus  String?
  toStatus    String?
  reasonCode  String?
  notes       String?
  metadata    Json?
  changedById String?
  createdAt   DateTime @default(now())
  changedBy   Staff?   @relation(fields: [changedById], references: [id])
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([orderId, createdAt])
}

model Service {
  id        String      @id @default(cuid())
  name      String
  category  String
  basePrice Decimal     @default(0) @db.Decimal(18, 2)
  isActive  Boolean     @default(true)
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())
  items     OrderItem[]
  ironLogs  IronLog[]

  @@index([category])
}

model IronSubscription {
  id                String    @id @default(cuid())
  customerId        String    @unique
  applicationStatus String    @default("PENDING_REVIEW")
  notes             String?
  appliedAt         DateTime  @default(now())
  confirmedAt       DateTime?
  confirmedById     String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  customer    Customer   @relation(fields: [customerId], references: [id])
  confirmedBy Staff?     @relation("IronSubscriptionConfirmedBy", fields: [confirmedById], references: [id])
  logs        IronLog[]
  bills       IronBill[]

  @@index([applicationStatus])
  @@map("iron_subscriptions")
}

model IronLog {
  id              String    @id @default(cuid())
  subscriptionId  String
  customerId      String
  serviceId       String
  serviceName     String
  date            DateTime
  pieces          Int
  ratePerPiece    Decimal   @db.Decimal(18, 2)
  amount          Decimal   @db.Decimal(18, 2)
  notes           String?
  whatsappSent    Boolean   @default(false)
  loggedById      String
  billId          String?
  status          String    @default("ACTIVE")
  rateSource      String    @default("CATALOG")
  pricingSnapshot Json?
  voidedAt        DateTime?
  voidReason      String?
  voidedById      String?
  createdAt       DateTime  @default(now())

  subscription IronSubscription @relation(fields: [subscriptionId], references: [id])
  customer     Customer         @relation(fields: [customerId], references: [id])
  service      Service          @relation(fields: [serviceId], references: [id])
  loggedBy     Staff            @relation("IronLogEnteredBy", fields: [loggedById], references: [id])
  voidedBy     Staff?           @relation("IronLogVoidedBy", fields: [voidedById], references: [id], onDelete: Restrict)
  bill         IronBill?        @relation(fields: [billId], references: [id])

  @@unique([customerId, serviceId, date])
  @@index([customerId])
  @@index([date])
  @@index([billId])
  @@index([customerId, date])
  @@map("iron_logs")
}

model IronBill {
  id                 String    @id @default(cuid())
  billNumber         String    @unique
  customerId         String
  subscriptionId     String
  billingPeriodStart DateTime
  billingPeriodEnd   DateTime
  totalPieces        Int
  totalAmount        Decimal   @db.Decimal(18, 2)
  status             String    @default("DRAFT")
  paidAt             DateTime?
  paidAmount         Decimal   @default(0) @db.Decimal(18, 2)
  paymentMethod      String?
  carryForwardNotes  String?
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  customer     Customer         @relation(fields: [customerId], references: [id])
  subscription IronSubscription @relation(fields: [subscriptionId], references: [id])
  logs         IronLog[]
  invoice      Invoice?

  @@unique([customerId, billingPeriodStart])
  @@index([customerId])
  @@map("iron_bills")
}

model Payment {
  id                   String              @id @default(cuid())
  orderId              String?
  amount               Decimal             @db.Decimal(18, 2)
  kind                 String              @default("RECEIPT")
  method               String
  reference            String?
  notes                String?
  createdAt            DateTime            @default(now())
  collectedBy          String?
  razorpayOrderId      String?
  razorpayPaymentId    String?
  razorpaySignature    String?
  status               String              @default("CAPTURED")
  idempotencyKey       String?             @unique
  referenceFingerprint String?             @unique
  reversedAt           DateTime?
  reversalReason       String?
  reversalOfId         String?
  customerId           String
  mode                 String?
  collectedByStaff     Staff?              @relation(fields: [collectedBy], references: [id])
  order                Order?              @relation(fields: [orderId], references: [id], onDelete: Restrict)
  customer             Customer            @relation(fields: [customerId], references: [id], onDelete: Restrict)
  reversalOf           Payment?            @relation("PaymentReversals", fields: [reversalOfId], references: [id], onDelete: Restrict)
  reversals            Payment[]           @relation("PaymentReversals")
  allocations          PaymentAllocation[]
  refundAllocations    RefundAllocation[]  @relation("RefundPaymentAllocations")
  receipt              Receipt?
  creditNote           CreditNote?         @relation("CreditNoteRefundPayment")

  @@index([orderId])
  @@index([method, createdAt])
  @@index([collectedBy, createdAt])
}

model PaymentAllocation {
  id                String             @id @default(cuid())
  paymentId         String
  orderId           String?
  invoiceId         String
  amount            Decimal            @db.Decimal(18, 2)
  status            String             @default("POSTED")
  reversedAt        DateTime?
  reason            String?
  createdAt         DateTime           @default(now())
  payment           Payment            @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  order             Order?             @relation(fields: [orderId], references: [id], onDelete: Restrict)
  invoice           Invoice            @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  refundAllocations RefundAllocation[]
  receiptAllocation ReceiptAllocation?

  @@unique([paymentId, invoiceId])
  @@index([orderId, status])
  @@index([invoiceId, status])
  @@index([paymentId, status])
  @@map("payment_allocations")
}

model Invoice {
  id                 String              @id @default(cuid())
  invoiceNumber      String              @unique
  customerId         String
  orderId            String?             @unique
  ironBillId         String?             @unique
  sourceType         String
  status             String              @default("OPEN")
  currency           String              @default("INR")
  issueDate          DateTime            @default(now())
  dueDate            DateTime
  subtotal           Decimal             @db.Decimal(18, 2)
  discountAmount     Decimal             @default(0) @db.Decimal(18, 2)
  taxAmount          Decimal             @default(0) @db.Decimal(18, 2)
  totalAmount        Decimal             @db.Decimal(18, 2)
  paidAmount         Decimal             @default(0) @db.Decimal(18, 2)
  creditAmount       Decimal             @default(0) @db.Decimal(18, 2)
  balanceDue         Decimal             @db.Decimal(18, 2)
  paymentTermsDays   Int                 @default(7)
  version            Int                 @default(1)
  postedAt           DateTime?
  voidedAt           DateTime?
  voidReason         String?
  createdById        String?
  postedById         String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  customer           Customer            @relation(fields: [customerId], references: [id], onDelete: Restrict)
  order              Order?              @relation(fields: [orderId], references: [id], onDelete: Restrict)
  ironBill           IronBill?           @relation(fields: [ironBillId], references: [id], onDelete: Restrict)
  createdBy          Staff?              @relation("InvoiceCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  postedBy           Staff?              @relation("InvoicePostedBy", fields: [postedById], references: [id], onDelete: Restrict)
  lines              InvoiceLine[]
  allocations        PaymentAllocation[]
  revisions          InvoiceRevision[]
  creditNotes        CreditNote[]
  refundAllocations  RefundAllocation[]
  receipts           Receipt[]
  receiptAllocations ReceiptAllocation[]

  @@index([customerId, status, dueDate])
  @@index([status, dueDate])
  @@index([issueDate])
  @@map("invoices")
}

model InvoiceLine {
  id              String           @id @default(cuid())
  invoiceId       String
  orderItemId     String?
  lineType        String           @default("SERVICE")
  description     String
  quantity        Decimal          @default(1) @db.Decimal(18, 3)
  unitPrice       Decimal          @db.Decimal(18, 2)
  discountAmount  Decimal          @default(0) @db.Decimal(18, 2)
  taxAmount       Decimal          @default(0) @db.Decimal(18, 2)
  lineTotal       Decimal          @db.Decimal(18, 2)
  metadata        Json?
  createdAt       DateTime         @default(now())
  invoice         Invoice          @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  orderItem       OrderItem?       @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  creditNoteLines CreditNoteLine[]

  @@index([invoiceId])
  @@index([orderItemId])
  @@map("invoice_lines")
}

model InvoiceRevision {
  id          String   @id @default(cuid())
  invoiceId   String
  version     Int
  reason      String
  snapshot    Json
  createdById String?
  createdAt   DateTime @default(now())
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  createdBy   Staff?   @relation("InvoiceRevisionCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@unique([invoiceId, version])
  @@index([createdAt])
  @@map("invoice_revisions")
}

model RefundAllocation {
  id                 String            @id @default(cuid())
  refundPaymentId    String
