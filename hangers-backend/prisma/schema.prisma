  allocations     VendorPaymentAllocation[]

  @@unique([plantPartnerId, vendorInvoiceNo])
  @@index([plantPartnerId, status, dueDate])
  @@map("vendor_bills")
}

model VendorPayment {
  id             String                    @id @default(cuid())
  paymentNo      String                    @unique
  plantPartnerId String
  amount         Decimal                   @db.Decimal(18, 2)
  method         String
  reference      String?
  status         String                    @default("CAPTURED")
  paidAt         DateTime                  @default(now())
  notes          String?
  recordedById   String
  createdAt      DateTime                  @default(now())
  plantPartner   PlantPartner              @relation(fields: [plantPartnerId], references: [id], onDelete: Restrict)
  recordedBy     Staff                     @relation("VendorPaymentRecordedBy", fields: [recordedById], references: [id], onDelete: Restrict)
  allocations    VendorPaymentAllocation[]

  @@index([plantPartnerId, paidAt])
  @@map("vendor_payments")
}

model VendorPaymentAllocation {
  id              String        @id @default(cuid())
  vendorPaymentId String
  vendorBillId    String
  amount          Decimal       @db.Decimal(18, 2)
  createdAt       DateTime      @default(now())
  vendorPayment   VendorPayment @relation(fields: [vendorPaymentId], references: [id], onDelete: Restrict)
  vendorBill      VendorBill    @relation(fields: [vendorBillId], references: [id], onDelete: Restrict)

  @@unique([vendorPaymentId, vendorBillId])
  @@index([vendorBillId, createdAt])
  @@map("vendor_payment_allocations")
}

model PlantPartner {
  id               String              @id @default(cuid())
  code             String              @unique
  name             String
  legalName        String?
  gstin            String?
  contactName      String?
  phone            String?
  email            String?
  address          String?
  paymentTermsDays Int                 @default(15)
  isActive         Boolean             @default(true)
  notes            String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  challans         DeliveryChallan[]
  vendorPrices     VendorPriceList[]
  vendorBills      VendorBill[]
  vendorPayments   VendorPayment[]
  transfersFrom    TransferOrder[]     @relation("TransferFromPlant")
  transfersTo      TransferOrder[]     @relation("TransferToPlant")
  garmentUnits     GarmentUnit[]
  qualityIssues    PlantQualityIssue[]

  @@index([isActive, name])
  @@map("plant_partners")
}

model Campaign {
  id          String    @id @default(cuid())
  name        String
  message     String
  audience    String
  channel     String    @default("WHATSAPP")
  status      String    @default("DRAFT")
  sentCount   Int       @default(0)
  failedCount Int       @default(0)
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime  @default(now())

  @@map("campaigns")
}

model Automation {
  id         String   @id @default(cuid())
  name       String
  trigger    String
  channel    String   @default("WHATSAPP")
  message    String
  delayHours Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("automations")
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("settings")
}

enum StaffRole {
  SUPER_ADMIN
  MANAGER
  COUNTER_STAFF
  ACCOUNTS
  DELIVERY_MANAGER
  DELIVERY_RIDER
  PLANT_MANAGER
  PLANT_STAFF
  PLANT_QC
}

enum OtpPurpose {
  LOGIN
  REGISTER
  RESET
  DELIVERY
}

enum AuthChallengePurpose {
  CUSTOMER_LOGIN
  DELIVERY_CONFIRMATION
}

enum AuthChallengeStatus {
  PENDING
  VERIFIED
  EXPIRED
  LOCKED
  CANCELLED
}

enum AuditEventStatus {
  SUCCESS
  FAILURE
  DENIED
}

enum OrderStatus {
  PENDING
  PICKED_UP
  PROCESSING
  WASHING
  DRYING
  IRONING
  QC
  READY_FOR_DELIVERY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  RETURNED
  SENT_TO_PLANT
}
